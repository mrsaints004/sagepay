# Particle Network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=your_particle_project_id
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=your_particle_client_key
NEXT_PUBLIC_PARTICLE_APP_UUID=your_particle_app_uuid

# Magic.link
NEXT_PUBLIC_MAGIC_API_KEY=your_magic_api_key

# Groq (optional - falls back to local intent parser)
GROQ_API_KEY=your_groq_api_key

# Vercel Postgres (auto-populated when linked via Vercel dashboard)
DATABASE_URL=postgres://...
POSTGRES_URL=postgres://...

# Chain environment: "testnet" (default) or "mainnet"
NEXT_PUBLIC_CHAIN_ENV=testnet

# Sentry (optional - error monitoring)
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# CORS (optional - comma-separated allowed origins)
ALLOWED_ORIGINS=https://yourdomain.com
